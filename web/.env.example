# Base URL of the FastAPI backend.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# No-auth dev mode. When true, Clerk is skipped and every request acts as a single
# "dev_user" (pair with the API's DEV_AUTH_BYPASS=true). Lets you run the app with no
# Clerk keys. Set to false for real sign-in.
NEXT_PUBLIC_AUTH_DISABLED=false

# Clerk keys — from your Clerk dashboard (https://dashboard.clerk.com).
# Required only when NEXT_PUBLIC_AUTH_DISABLED=false.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
