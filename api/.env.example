# --- Database ---
DATABASE_URL=postgresql+psycopg://taskmarket:taskmarket@localhost:5432/taskmarket

# --- Clerk JWT verification ---
# Find these in your Clerk dashboard. JWKS URL looks like:
#   https://<your-subdomain>.clerk.accounts.dev/.well-known/jwks.json
# Issuer is the `iss` on Clerk session tokens:
#   https://<your-subdomain>.clerk.accounts.dev
CLERK_JWKS_URL=
CLERK_ISSUER=
# Optional. Leave blank to skip audience verification.
CLERK_AUDIENCE=

# --- Local dev convenience ---
# When true, /v1/me skips Clerk verification and returns a synthetic dev user.
# Use this to exercise the API locally without a real token. NEVER enable in production.
DEV_AUTH_BYPASS=true

# --- CORS ---
# Comma-separated list of allowed web origins.
CORS_ORIGINS=http://localhost:3000
