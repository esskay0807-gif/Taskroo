# --- Database ---
DATABASE_URL=postgresql+psycopg://taskmarket:taskmarket@localhost:5432/taskmarket

# --- Clerk JWT verification ---
# Find these in your Clerk dashboard. JWKS URL looks like:
#   https://<your-subdomain>.clerk.accounts.dev/.well-known/jwks.json
# Issuer is the `iss` on Clerk session tokens:
#   https://<your-subdomain>.clerk.accounts.dev
CLERK_JWKS_URL=
CLERK_ISSUER=
# Optional. Leave blank to skip audience verification.
CLERK_AUDIENCE=

# --- Local dev convenience ---
# When true, /v1/me skips Clerk verification and returns a synthetic dev user.
# Use this to exercise the API locally without a real token. NEVER enable in production.
DEV_AUTH_BYPASS=true

# --- CORS ---
# Comma-separated list of allowed web origins. MUST include the port the Next.js dev
# server actually runs on (it falls back from 3000 if that port is taken — e.g. 4400),
# otherwise the browser blocks API calls and pages show no data.
CORS_ORIGINS=http://localhost:3000,http://localhost:4400

# Public base URL of this API (used to build dev upload URLs when R2 is unconfigured).
API_BASE_URL=http://localhost:8000

# --- Cloudflare R2 (avatar uploads) ---
# Leave blank to use the local dev upload fallback (presign returns a URL served by
# this API instead of R2). Fill these in to use real R2 presigned uploads.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public base URL for objects (e.g. an R2 public bucket or CDN domain).
R2_PUBLIC_BASE_URL=

# --- Razorpay (TEST MODE) ---
# Leave KEY_ID/KEY_SECRET blank to use the dev payment fallback (simulates
# authorize->held on checkout and capture->released on complete). Fill in your
# Razorpay TEST keys to use the real checkout widget + capture.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook signing secret (set this and the same value in the Razorpay dashboard webhook).
RAZORPAY_WEBHOOK_SECRET=

# Platform service fee percent, deducted from the agreed amount at release.
SERVICE_FEE_PERCENT=15

# --- Resend (transactional email) ---
# Leave RESEND_API_KEY blank to log emails to the console instead of sending.
RESEND_API_KEY=
RESEND_FROM=TaskMarket <onboarding@resend.dev>

# --- Rate limiting ---
# Max write requests per identity per minute (in-memory, single instance).
RATE_LIMIT_PER_MINUTE=120
